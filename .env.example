# EspritConnect environment configuration
# Copy this file to .env and fill in real values before running docker-compose
# NEVER commit the actual .env file to version control

MYSQL_ROOT_PASSWORD=root
DB_USERNAME=root
DB_PASSWORD=root

# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=esprit-connect-super-secret-key-must-be-at-least-256-bits-long

CORS_ALLOWED_ORIGINS=http://localhost:4200
