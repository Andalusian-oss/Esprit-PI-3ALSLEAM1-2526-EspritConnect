# EspritConnect environment configuration
# Copy this file to .env and fill in real values before running docker-compose
# NEVER commit the actual .env file to version control

MYSQL_ROOT_PASSWORD=root
DB_USERNAME=root
DB_PASSWORD=root

# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=esprit-connect-super-secret-key-must-be-at-least-256-bits-long

CORS_ALLOWED_ORIGINS=http://localhost:4200

# AI Chatbot — set ONE or BOTH keys (OpenAI takes priority over Groq)
# OpenAI (GPT-4o-mini): https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Groq (LLaMA 3, free): https://console.groq.com
GROQ_API_KEY=
